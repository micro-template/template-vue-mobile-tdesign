    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@ailearning/eslint-config": "workspace:^",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@iconify/vue": "^5.0.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "less": "^4.6.4",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
